{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "blacktape-desktop",
  "version": "0.1.0",
  "identifier": "com.github.seafoodd.blacktape",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "plugins": {
    "sql": {
      "preload": ["sqlite:blacktape.db"]
    }
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "transparent": true,
        "title": "blacktape-desktop",
        "width": 1280,
        "height": 720,
        "minWidth": 800,
        "minHeight": 320
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "android": {
      "minSdkVersion": 26
    },
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
